{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfigPath": "api/nixpacks.toml",
    "watchPatterns": ["api/**"]
  },
  "deploy": {
    "startCommand": "cd api && uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "restartPolicyType": "ON_FAILURE"
  }
}
